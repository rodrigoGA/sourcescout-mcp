{
  "name": "sourcescout-mcp",
  "version": "0.0.4",
  "description": "SourceScout MCP exposes read-only code search, file inspection, Probe, and Git utilities over MCP HTTP.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.7.6",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@probelabs/probe": "0.6.0-rc316",
    "minimatch": "^10.0.1",
    "yaml": "^2.6.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
