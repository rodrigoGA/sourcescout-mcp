{
  "name": "sourcescout-mcp",
  "version": "0.0.10",
  "description": "SourceScout MCP exposes multi-repository read-only shell inspection over MCP HTTP.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.7.6",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "jsesc": "^3.1.0",
    "yaml": "^2.6.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/jsesc": "^3.0.3",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
